#!/bin/bash

# Configure logging format
log() {
    echo "$(date '+%H:%M:%S') [WATCHDOG] $1"
}

# Ignore all standard signals to prevent accidental termination by fuzzed programs.
# This script ensures persistence and can only be stopped via 'kill -9 <pid>'.
trap "" SIGINT SIGTERM SIGHUP SIGQUIT SIGABRT SIGUSR1 SIGUSR2

# Prevent core dumps from filling disk which can cause crashes
ulimit -c 0

# Construct the command
CMD="python3 main.py $@"

log "Starting watchdog for: $CMD"
log "WARNING: Signals blocked. Use 'kill -9 $$' to stop this watchdog."

# Attempt to protect watchdog from OOM killer (if running as root/privileged)
# -1000 means "never kill"
if [ -w /proc/$$/oom_score_adj ]; then
    echo -1000 > /proc/$$/oom_score_adj 2>/dev/null && log "Adjusted OOM score to -1000 (Protected)"
fi

restart_count=0

while true; do
    restart_count=$((restart_count + 1))
    log "--- Starting Fuzzer (Attempt $restart_count) ---"
    
    # Capture start time for duration check
    start_time=$(date +%s)
    
    # Run the fuzzer in background and wait
    # This structure is more robust against signal propagation issues
    python3 main.py "$@" &
    worker_pid=$!
    wait $worker_pid
    exit_code=$?
    
    end_time=$(date +%s)
    duration=$((end_time - start_time))

    # Check exit code
    if [ $exit_code -eq 0 ]; then
        log "Fuzzer exited successfully (Exit Code 0)."
        # Exit code 0 implies intended stop (e.g. finished iterations)
        log "Stopping watchdog as fuzzer finished normally."
        break
    else
        # 137 = 128 + 9 (SIGKILL), usually OOM
        if [ $exit_code -eq 137 ]; then
             log "Fuzzer was KILLED (Exit Code 137). Likely Out-Of-Memory (OOM)."
             log "The watchdog will restart a fresh process."
        else
             log "Fuzzer terminated with Exit Code $exit_code."
        fi
        
        # Check for rapid failures (crashed in less than 5 seconds)
        if [ $duration -lt 5 ]; then
            log "Fuzzer crashed too quickly (< 5s). Waiting 10 seconds before restart to prevent thrashing..."
            sleep 10
        else
            log "Restarting fuzzer in 1 second..."
            sleep 1
        fi
    fi
done
